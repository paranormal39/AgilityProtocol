{
  "name": "agility-summit",
  "version": "1.0.0",
  "description": "AGI - Seamless Crypto Abstraction AI Agent for Privacy-First E-commerce",
  "main": "agents/agi-server.js",
  "scripts": {
    "start": "cd agents && npm start",
    "dev": "cd agents && npm run dev",
    "setup": "cd agents && npm run setup",
    "compile": "bash -lc 'mkdir -p build && for f in contracts/*.compact; do compact compile \"$f\" build; done'",
    "deploy:testnet": "node scripts/deploy.js --network testnet",
    "deploy:mainnet": "node scripts/deploy.js --network mainnet"
  },
  "keywords": [
    "midnight",
    "blockchain",
    "privacy",
    "zkp",
    "xrpl",
    "payments",
    "web3"
  ],
  "author": "Agility Team",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.7.0"
  }
}
